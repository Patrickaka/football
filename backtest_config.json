{
  "description": "回测与超参数优化配置文件",
  
  "backtest": {
    "default_league": "英超",
    "default_start_date": "2024-01-01",
    "default_end_date": "2024-12-31",
    "window_size": 20,
    "min_matches_required": 10,
    "cache_enabled": true,
    "cache_ttl_hours": 24
  },
  
  "evaluation_metrics": {
    "primary_metric": "log_loss",
    "secondary_metrics": ["brier_score", "top1_accuracy", "top2_accuracy", "top3_accuracy"],
    "target_accuracy": 0.65,
    "log_loss_threshold": 0.6
  },
  
  "hyperparameter_search_space": {
    "FIT_W_1X2": {
      "type": "float",
      "min": 0.5,
      "max": 2.0,
      "step": 0.1,
      "description": "欧赔权重"
    },
    "FIT_W_OVER": {
      "type": "float",
      "min": 0.3,
      "max": 1.5,
      "step": 0.1,
      "description": "大小球权重"
    },
    "FIT_W_ASIAN": {
      "type": "float",
      "min": 0.3,
      "max": 1.5,
      "step": 0.1,
      "description": "亚盘权重"
    },
    "FIT_W_FORM": {
      "type": "float",
      "min": 0.1,
      "max": 1.0,
      "step": 0.1,
      "description": "球队状态权重"
    },
    "LAMBDA_REFINE_STEPS": {
      "type": "int",
      "min": 3,
      "max": 15,
      "step": 1,
      "description": "Lambda优化步数"
    },
    "LAMBDA_TOLERANCE": {
      "type": "float",
      "min": 1e-6,
      "max": 1e-3,
      "log_scale": true,
      "description": "Lambda优化容差"
    },
    "HEAT_RATIO_HOT": {
      "type": "float",
      "min": 0.5,
      "max": 1.5,
      "step": 0.1,
      "description": "热门比分阈值"
    },
    "HEAT_RATIO_COLD": {
      "type": "float",
      "min": 0.8,
      "max": 2.0,
      "step": 0.1,
      "description": "冷门比分阈值"
    },
    "HEAT_FILTER_WEIGHT": {
      "type": "float",
      "min": 0.5,
      "max": 1.0,
      "step": 0.05,
      "description": "冷热过滤权重"
    },
    "CONFIDENCE_LOW_THRESHOLD": {
      "type": "float",
      "min": 0.4,
      "max": 0.7,
      "step": 0.05,
      "description": "低置信度阈值"
    },
    "CONFIDENCE_HIGH_THRESHOLD": {
      "type": "float",
      "min": 0.7,
      "max": 0.95,
      "step": 0.05,
      "description": "高置信度阈值"
    },
    "KELLY_DEVIATION_THRESHOLD": {
      "type": "float",
      "min": 2.0,
      "max": 10.0,
      "step": 0.5,
      "description": "凯利偏差阈值"
    },
    "KELLY_SPREAD_THRESHOLD": {
      "type": "float",
      "min": 0.1,
      "max": 2.0,
      "step": 0.1,
      "description": "凯利离散阈值"
    },
    "RHO_INITIAL": {
      "type": "float",
      "min": -0.3,
      "max": 0.0,
      "step": 0.05,
      "description": "Dixon-Coles rho初始值"
    },
    "MAX_GOALS": {
      "type": "int",
      "min": 5,
      "max": 10,
      "step": 1,
      "description": "最大进球数"
    },
    "RESIDUAL_WEIGHT": {
      "type": "float",
      "min": 0.1,
      "max": 0.5,
      "step": 0.05,
      "description": "残差学习权重"
    },
    "DRAW_CALIBRATION_WEIGHT": {
      "type": "float",
      "min": 0.1,
      "max": 0.5,
      "step": 0.05,
      "description": "平局校准权重"
    }
  },
  
  "optuna_settings": {
    "study_name": "football_model",
    "n_trials": 100,
    "timeout_seconds": 3600,
    "pruner": {
      "type": "MedianPruner",
      "n_startup_trials": 5,
      "n_warmup_steps": 3,
      "interval_steps": 1
    },
    "sampler": {
      "type": "TPESampler",
      "n_startup_trials": 10
    }
  },
  
  "dynamic_threshold": {
    "window_size": 20,
    "initial_low_threshold": 0.5,
    "initial_high_threshold": 0.8,
    "min_low_threshold": 0.3,
    "max_low_threshold": 0.7,
    "sensitivity": 0.1,
    "target_accuracy": 0.65
  },
  
  "leagues": [
    "英超",
    "西甲",
    "德甲",
    "意甲",
    "法甲",
    "中超",
    "欧冠",
    "欧联杯",
    "友谊赛",
    "世界杯"
  ],
  
  "output": {
    "save_results": true,
    "results_dir": "backtest_results",
    "generate_plots": true,
    "plots_dir": "backtest_plots"
  }
}